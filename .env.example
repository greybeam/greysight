DATA_SOURCE=snowflake
AUTH_REQUIRED=false
NEXT_PUBLIC_AUTH_REQUIRED=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Auth (Supabase) ---
# AUTH_REQUIRED=true turns on magic-link login.
#
# Local (single shared .env): copy this file to `.env`, fill in the values, then
# run `npm run dev`. That auto-loads root `.env` for BOTH the web and API dev
# servers (tolerantly: a missing `.env` is fine and keeps zero-config demo mode
# working). `.env.local` is an optional Next.js-only personal override.
# Set each value ONCE below. The Next.js browser app reads the NEXT_PUBLIC_ vars,
# and the FastAPI server falls back to them too.
#
# Editing .env? The dev servers read it only at launch (the API's dev.py loads
# .env on start; `uvicorn --reload` reloads code, not env). After changing any
# value, fully restart `npm run dev` (stop and re-run) — saving the file is not
# enough.
#
# ANON / publishable key: paste your Supabase **Publishable key** (`sb_publishable_…`),
# from Dashboard > Project Settings > API keys > Publishable. It is browser-safe
# and was historically called the "anon" key (the var name is unchanged).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Split deployments only (API host does NOT share the web env): set these explicit
# server-only vars. When present they take precedence over the NEXT_PUBLIC_ values;
# when unset the API falls back to the NEXT_PUBLIC_ values above. Leave commented
# for the common local case. SUPABASE_ANON_KEY also takes the Publishable key.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
#
# Server-only. Paste your Supabase **Secret key** (`sb_secret_…`), from
# Dashboard > Project Settings > API keys > Secret keys. This is the new name for
# the legacy "service_role" key; it bypasses RLS for the live membership lookup,
# so it has no NEXT_PUBLIC_ twin and must NEVER reach the browser. REQUIRED when
# AUTH_REQUIRED=true. Do NOT paste the publishable key here.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=SNOWFLAKE
SNOWFLAKE_SCHEMA=ACCOUNT_USAGE
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

GREYSIGHT_QUERY_TIMEOUT_SECONDS=60
GREYSIGHT_DEFAULT_WINDOW_DAYS=30
STORAGE_PRICE_USD_PER_TB_MONTH=

# USD price per credit used for estimated dollar conversion when
# Organization Usage billing/rate data is unavailable.
ESTIMATED_CREDIT_PRICE_USD=3.00
